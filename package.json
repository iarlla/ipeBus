{
  "name": "ipebus",
  "version": "1.0.0",
  "description": "Projeto JavaScript para simulação de ônibus.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" \"tests/**/*.js\" --fix",
    "format": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "format:fix": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"*.js\""
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.9.5"
  }
}
