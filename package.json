{
  "name": "ipebus",
  "version": "1.0.0",
  "description": "Projeto JavaScript para simulação de ônibus.",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint \"src/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" \"tests/**/*.js\" --fix",
    "format": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "format:fix": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" \"*.js\"",
    "build:css": "tailwindcss -i ./src/input.css -o ./dist/tailwind.css",
    "watch:css": "tailwindcss -i ./src/input.css -o ./dist/tailwind.css --watch"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.4.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2"
  }
}
